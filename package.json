{
  "name": "jswidthbreakpoints",
  "version": "1.0.1",
  "description": "A lightweight, vanilla JavaScript library for handling responsive breakpoints with dynamic CSS classes and visual rules.",
  "main": "dist/JsWidthBreakpoints.js",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/JsWidthBreakpoints.js",
      "require": "./dist/JsWidthBreakpoints.js"
    }
  },
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "testMatch": [
      "**/__tests__/**/*.test.js",
      "**/?(*.)+(spec|test).js",
      "**/**tests**/**/*.test.js"
    ]
  },
  "keywords": [
    "responsive",
    "breakpoints",
    "javascript",
    "vanilla-js",
    "css-classes",
    "media-queries",
    "responsive-design",
    "frontend",
    "web-development"
  ],
  "author": "Marcelo XP",
  "homepage": "https://github.com/marceloxp/JsWidthBreakpoints",
  "license": "MIT",
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "gulp": "^5.0.0",
    "gulp-concat": "^2.6.1",
    "gulp-header": "^2.0.9",
    "gulp-rename": "^2.0.0",
    "gulp-terser": "^2.1.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "jsdom": "^29.0.0",
    "merge-stream": "^2.0.0"
  }
}